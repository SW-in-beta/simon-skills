{
  "colors": {
    "primary": "#6366f1",
    "primaryHover": "#4f46e5",
    "primaryLight": "#eef2ff",
    "secondary": "#f43f5e",
    "secondaryHover": "#e11d48",
    "background": "#fafafa",
    "surface": "#ffffff",
    "surfaceHover": "#f5f5f5",
    "text": "#171717",
    "textSecondary": "#737373",
    "textTertiary": "#a3a3a3",
    "border": "#e5e5e5",
    "borderFocus": "#6366f1",
    "error": "#ef4444",
    "errorLight": "#fef2f2",
    "success": "#22c55e",
    "successLight": "#f0fdf4",
    "warning": "#f59e0b",
    "like": "#ef4444",
    "gradient": {
      "primary": "from-indigo-500 via-purple-500 to-pink-500",
      "subtle": "from-indigo-50 to-pink-50"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, system-ui, -apple-system, sans-serif",
      "display": "Inter, system-ui, -apple-system, sans-serif"
    },
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "weights": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem"
  },
  "borderRadius": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1)"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "animation": {
    "transition": "all 0.2s ease-in-out",
    "heartBeat": "heartbeat 0.3s ease-in-out"
  }
}
